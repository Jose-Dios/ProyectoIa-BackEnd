# Puerto del servidor
PORT=3000

# URL pública usada para construir el enlace de descarga del ZIP
URL_PUBLICA=http://localhost:3000

# Orígenes permitidos para CORS, separados por coma. Vacío = permitir todos.
CORS_ORIGENES=http://localhost:5173

# Persistencia: "mongo" (requiere Docker/MongoDB) o "memoria" (sin dependencias,
# los datos se pierden al reiniciar el servidor). Útil para desarrollo y demos.
BD_MODO=memoria

# Conexión a MongoDB. Solo se usa si BD_MODO=mongo.
# Cambia usuario y contraseña en producción.
BD_LINK=mongodb://admin:admin123@localhost:27017/proyecto_ia?authSource=admin

# Endpoint de Ollama.
# Usa 127.0.0.1 y NO "localhost": Ollama escucha solo en IPv4, mientras que Node
# resuelve "localhost" primero a ::1 (IPv6) y la conexion falla con ECONNREFUSED.
OLLAMA=http://127.0.0.1:11434/api/chat

# Modelo de IA (puede cambiarse)
MODELO=qwen2.5-coder:3b

# Opcional: endpoint para descargar el modelo de memoria.
# Por defecto se usa el mismo que OLLAMA con keep_alive: 0.
# PAUSA=http://localhost:11434/api/chat

# Tiempo máximo de espera de una generación (ms)
OLLAMA_TIMEOUT_MS=300000

# Llamadas a la IA antes de descargar el modelo y liberar memoria
LLAMADAS_ANTES_DE_REINICIAR=6

# --- Reproducibilidad (importante para resultados replicables) ---
# Temperatura baja = salida más determinista
TEMPERATURA=0.1
# Semilla fija: con la misma semilla y temperatura, el modelo repite la salida
SEED=42
# Ventana de contexto del modelo (tokens)
NUM_CTX=8192

# --- Límites del análisis de proyectos ---
MAX_ARCHIVOS=10
MAX_BYTES_POR_ARCHIVO=50000
MAX_CARACTERES_REFACTOR=12000
TAMANIO_GRUPO=3

# Verificar que el código refactorizado compile; si no, se conserva el original
VALIDAR_SINTAXIS=true

# Verificar que el refactor no elimine ni renombre exportaciones ni rutas HTTP.
# Que un archivo compile no significa que siga sirviendo para lo mismo.
VALIDAR_CONTRATO=true
